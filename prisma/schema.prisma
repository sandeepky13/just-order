datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  fullName      String
  mobile        String          @unique
  email         String          @unique
  address       String
  passwordHash  String
  createdAt     DateTime        @default(now())
  
  // Relations
  cartItems     CartItem[]
  wishlist      Wishlist[]
  orders        Order[]
  searchHistory SearchHistory[]
  clickEvents   ClickEvent[]
  userEvents    UserEvent[]
  loginHistory  LoginHistory[]
  pageVisits    PageVisit[]
  reviews       Review[]
  addresses     Address[]
  notifications Notification[]
}

model Product {
  id            String       @id @default(uuid())
  name          String
  description   String
  price         Float
  discount      Float        @default(0) // percentage
  rating        Float        @default(5.0)
  stockStatus   String       @default("In Stock") // "In Stock" | "Low Stock" | "Out of Stock"
  stockCount    Int          @default(100)
  category      String
  brand         String
  imageUrl      String
  
  // Relations
  cartItems     CartItem[]
  wishlist      Wishlist[]
  orderItems    OrderItem[]
  clickEvents   ClickEvent[]
  reviews       Review[]
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  imageUrl  String?
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
}

model Order {
  id            String         @id @default(uuid())
  userId        String
  orderDate     DateTime       @default(now())
  amount        Float
  paymentStatus String         @default("Pending") // "Paid" | "Pending" | "Failed"
  orderStatus   String         @default("Successful") // "Successful" | "Pending" | "Cancelled" | "Returned"
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  payments      Payment[]
  cancellations Cancellation[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int
  
  // Relations
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  returns   Return[]
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String?
  keyword   String
  timestamp DateTime @default(now())
  ipAddress String
  device    String
  browser   String
  category  String?
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClickEvent {
  id            String   @id @default(uuid())
  userId        String?
  productId     String
  productName   String
  category      String
  buttonClicked String
  timestamp     DateTime @default(now())
  pageUrl       String
  ipAddress     String
  device        String
  browser       String
  
  // Relations
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model UserEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String // "Login" | "Logout" | "PageVisit"
  pageUrl   String?
  duration  Int?     // session duration in seconds
  timestamp DateTime @default(now())
  device    String
  browser   String
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  timestamp DateTime @default(now())
  ipAddress String
  device    String
  browser   String
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PageVisit {
  id        String   @id @default(uuid())
  userId    String?
  pageUrl   String
  referrer  String?
  timestamp DateTime @default(now())
  device    String
  browser   String
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  amount        Float
  status        String   @default("Pending") // "Paid" | "Pending" | "Failed"
  provider      String   @default("Card")
  transactionId String?
  timestamp     DateTime @default(now())
  
  // Relations
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Return {
  id           String   @id @default(uuid())
  orderItemId  String
  reason       String
  status       String   @default("Pending") // "Pending" | "Approved" | "Rejected"
  timestamp    DateTime @default(now())
  
  // Relations
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model Cancellation {
  id        String   @id @default(uuid())
  orderId   String
  reason    String
  status    String   @default("Pending")
  timestamp DateTime @default(now())
  
  // Relations
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String
  timestamp DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  title      String   @default("Home") // "Home" | "Work" etc
  fullName   String
  mobile     String
  street     String
  city       String
  state      String
  postalCode String
  
  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsSummary {
  id          String   @id @default(uuid())
  metricName  String
  metricValue Float
  timestamp   DateTime @default(now())
}
